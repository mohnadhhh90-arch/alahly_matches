# .github/workflows/fetch_news.yml
name: Fetch Ahly News

on:
  schedule:
    # كل نص ساعة
    - cron: "*/30 * * * *"

jobs:
  update-news:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v3

      - name: Fetch RSS and save to file
        run: |
          curl -s https://cdn.feedcontrol.net/14485/26353-QqNsCBTHfLEzl.xml -o ahly_news.xml

      - name: Commit and push changes
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          git add ahly_news.xml
          git commit -m "Update Ahly news from RSS [skip ci]" || echo "No changes to commit"
          git push
